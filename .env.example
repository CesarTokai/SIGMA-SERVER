# ===== SERVIDOR =====
# IP pública o dominio del servidor
SERVER_IP=tu-ip-publica.com

# ===== BASE DE DATOS =====
# Contraseña root MySQL (cambiar por valor seguro)
# Generar: openssl rand -base64 32
DB_ROOT_PASSWORD=change_me_securely_32_chars_min

# Nombre de la base de datos
DB_NAME=sigmav2

# Usuario adicional MySQL (opcional)
DB_USER=sigmav2_user
DB_PASSWORD=change_me_securely_32_chars_min

# ===== SEGURIDAD - JWT =====
# Secret para firmar JWT tokens (cambiar por valor seguro)
# Generar: openssl rand -base64 64
JWT_SECRET=change_me_securely_64_chars_min

# Expiración JWT en milisegundos (86400000 = 24 horas)
JWT_EXPIRATION=86400000

# ===== APLICACIÓN =====
# Ambiente (development, staging, production)
ENVIRONMENT=production

# Puerto backend interno (no cambiar normalmente)
BACKEND_PORT=8080

# Puerto frontend interno (no cambiar normalmente)
FRONTEND_PORT=80

# Puerto proxy público (no cambiar normalmente)
PROXY_PORT=80
